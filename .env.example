GATEWAY_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# OpenRouter — LLM narrative generation
# https://openrouter.ai/keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
# Model for narrative generation (default: anthropic/claude-3.5-haiku)
# See https://openrouter.ai/models for options
AXON_NARRATIVE_MODEL=anthropic/claude-3.5-haiku
AXON_NARRATIVE_MAX_TOKENS=1024

BONFIRE_ID=69b5aa116b9224b9492ba423
AGENT_ID=69b5a86a6b9224b9492ba422

# ---------------------------------------------------------------------------
# Natural Language Agreements (Arkhai Alkahest)
# https://github.com/arkhai-io/natural-language-agreements
# ---------------------------------------------------------------------------
NLA_API_KEY=
AXON_NLA_ENDPOINT=https://api.arkhai.io/nla
AXON_NLA_CHAIN=base

# ---------------------------------------------------------------------------
# Unbrowse.ai — external web context / action layer
# https://unbrowse.ai
# `npx unbrowse setup` to get API key
# ---------------------------------------------------------------------------
UNBROWSE_API_KEY=
AXON_UNBROWSE_API_URL=https://api.unbrowse.ai
AXON_UNBROWSE_TIMEOUT_S=8.0
AXON_UNBROWSE_CORPUS_THRESHOLD=0.35
